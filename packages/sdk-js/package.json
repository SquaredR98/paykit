{
  "name": "@squaredr/paykit-js",
  "version": "1.0.0",
  "description": "Vanilla JavaScript/TypeScript frontend SDK for @squaredr/paykit",
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    },
    "./providers/stripe": {
      "types": "./dist/providers/stripe.d.ts",
      "import": "./dist/providers/stripe.js",
      "require": "./dist/providers/stripe.cjs"
    },
    "./providers/razorpay": {
      "types": "./dist/providers/razorpay.d.ts",
      "import": "./dist/providers/razorpay.js",
      "require": "./dist/providers/razorpay.cjs"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsup",
    "test": "vitest run",
    "test:watch": "vitest",
    "typecheck": "tsc --noEmit",
    "clean": "rimraf dist"
  },
  "keywords": [
    "payments",
    "paykit",
    "frontend",
    "sdk",
    "javascript",
    "typescript",
    "headless"
  ],
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/SquaredR98/paykit.git",
    "directory": "packages/sdk-js"
  },
  "homepage": "https://squaredr.tech/products/paykit",
  "publishConfig": {
    "access": "public",
    "registry": "https://registry.npmjs.org/"
  },
  "peerDependencies": {
    "@squaredr/paykit": ">=0.2.0"
  },
  "devDependencies": {
    "@squaredr/paykit": "*",
    "jsdom": "^24.0.0",
    "rimraf": "^6.0.0",
    "tsup": "^8.3.0",
    "typescript": "^5.7.0",
    "vitest": "^3.0.0"
  }
}
