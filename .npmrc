# Enable hoisting in npm workspaces
hoist=true

# Prefer exact versions when installing dependencies
save-exact=false

# Strict peer dependencies (warn but don't fail)
legacy-peer-deps=false

# Audit level (moderate: ignore low vulnerabilities)
audit-level=moderate

# Public access by default for @squaredr scope
access=public

# Registry
registry=https://registry.npmjs.org/
